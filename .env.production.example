# Production / Vercel environment. Set these in Vercel:
#   Project → Settings → Environment Variables (Production + Preview).
# Do NOT commit real values. These come from your HOSTED Supabase project
# (Supabase Dashboard → Project Settings → API), not from `supabase status`.

# Hosted Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""

# Public anon key (safe for the browser; RLS is what protects data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service-role key — SERVER ONLY. Powers the cron worker and the seed script.
# Never prefix with NEXT_PUBLIC_ and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# Protects /api/cron/generate-alerts. Use a long random string.
# Vercel Cron automatically sends this as `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=""

# Demo controls. Exposes a DESTRUCTIVE one-click "Reset demo" that wipes and
# reseeds all demo orgs, plus a time-travel slider. Leave UNSET (or "false") in
# production — the server actions also hard-refuse unless this is exactly "true".
# NEXT_PUBLIC_DEMO_MODE="false"
